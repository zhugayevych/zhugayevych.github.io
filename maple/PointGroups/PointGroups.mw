<Group labelreference="L58942" drawlabel="true">
<Input><Text-field style="Normal" layout="Normal">Rotation group decomposition by characters</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">p:=NULL:
FG_ChTb(PG,fulloutput),Matrix([seq(Vector([convert(L,string),op(FG_RepDecCh(map(ChDL,PG:-nameC,L,p),ChTb,PG:-NC))]),L=0..6)]);</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
<Group labelreference="L58945" drawlabel="true">
<Input><Text-field style="Normal" layout="Normal">Rotation group decomposition by projectors</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">L:=2:
a:=Matrix(2*L+1,(i,j)-&gt;simplify(WignerD(L,L-i+1,L-j+1,0,0,Pi))):
b:=Matrix(2*L+1,(i,j)-&gt;simplify(WignerD(L,L-i+1,L-j+1,Pi,Pi,0))):
c:=(-1)^L*DiagonalMatrix([1$2*L+1]):
R:=PG:-GF([a,b,c]):
ls:=FG_RepDec(R,PG):
seq(v[1],v=ls);</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">NiZRJEExZzYiUSRBMmdGJFEkQjFnRiRRJEIyZ0Yk</Equation></Text-field>
</Output>
</Group>
<Group labelreference="L58944" drawlabel="true">
<Input><Text-field style="Normal" layout="Normal">Eigenfunction</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">i:=2:
M0:=ls[i][2][1]:
NM:=map(sqrt,HT(M0).M0)^(-1):
M1:=simplify(M0.NM):
M:=YxyzM(L,&quot;cubic&quot;):
M2:=simplify(M.M1):
ls[i][1],M0,M1,M2,HT(M2).map(angles2xyz,M.Vector(2*L+1,i-&gt;Ylm(L,L-i+1,theta,phi)));</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
<Group labelreference="L59116" drawlabel="true">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">RepDim(&quot;F2&quot;),RepDim(&quot;D3&quot;),RepDim(&quot;&quot;);</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">NiUiIiQiIigiIiI=</Equation></Text-field>
</Output>
</Group>

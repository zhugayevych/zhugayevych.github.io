<Group labelreference="L59094" drawlabel="true">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">with(MolMod):
unassign('x,y,z,E');
CorrectErep:=proc(M0::Matrix,$) local M,i,a;
  M:=simplify(M0.&lt;&lt;1,1&gt;|&lt;I,-I&gt;&gt;/sqrt(2));
  for i from 1 to Dim2(M)[1] while (M[i,1]=0) do end;
  M:=simplify(exp(-I*argument(M[i,1]))*M);
  if (Norm(Im(M),Frobenius)=0) then M else WARNING(&quot;Algorithm error for %1&quot;,M0,M) end end:</Text-field>
</Input>
</Group>

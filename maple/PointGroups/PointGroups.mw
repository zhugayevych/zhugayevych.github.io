<Input><Text-field style="Text" layout="Normal">Test by alternative solution</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">unassign('c');
for v in L do  IR:=v[1];  n:=RepDim(IR);  eqs:={}: 
 for i in geni do  T,T1,T2:=IRT[IR][i],IRT[IR1][i],IRT[IR2][i];
   eqs:={op(eqs),seq(seq(seq(add(T[kk,ll]*c[kk,k1,k2],kk=1..n)=add(add(T1[k1,l1]*T2[k2,l2]*c[ll,l1,l2],l1=1..n1),l2=1..n2),ll=1..n),k1=1..n1),k2=1..n2)} end:
 sol:=solve({op(eqs)});   cs:=indets(map(rhs,sol));  if (nops(cs)&lt;&gt;1) then error(&quot;cs=%1&quot;,cs) end;
 kk,k1,k2:=op(cs[1]);  eq:=cs[1]=v[1+kk][k1,k2];  sol:={op(eval(sol,eq)),eq};
 CG:=[seq(Matrix(n1,n2,(k1,k2)-&gt;simplify(eval(c[kk,k1,k2],sol))),kk=1..n)];  #CG:=simplify(map(`/`,CG,Norm(CG[1],Frobenius)));
 for kk from 1 to n do if not(FG_ident(CG[kk],v[1+kk])) then print(IR,kk,CG[kk]&lt;&gt;v[1+kk]) end end end: printf(&quot;Done&quot;);</Text-field>
</Input>
<Output><Text-field style="Line Printed Output" layout="Line Printed Output">Done</Text-field>
</Output>
</Group>

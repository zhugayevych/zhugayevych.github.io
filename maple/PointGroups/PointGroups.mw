<Input><Text-field style="Text" layout="Normal">Determine symmetry unique elements</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">H1U,H2U:=table(),table():
for i from 1 to N do
 isnew:=true;
 for v in entries(H1U,nolist) do if (simplify(HE[i,i]-v)=0 or simplify(HE[i,i]+v)=0) then isnew:=false; break end end;
 if isnew then H1U[i]:=HE[i,i] end end:
H1U:=Sort([indices(H1U,nolist)]):
for i in H1U do [i],HE[i,i] end;
for i from 1 to N do for j from i+1 to N do
 isnew:=true;
 for v in entries(H2U,nolist) do if (simplify(HE[i,j]-v)=0 or simplify(HE[i,j]+v)=0 or simplify(subs(I=-I,HE[i,j])-v)=0 or
                                     simplify(subs(I=-I,HE[j,i])+v)=0) then isnew:=false; break end end;
 if isnew then H2U[i,j]:=HE[i,j] end end end:
H2U:=SortM([indices(H2U)],[1,2]):
for ij in H2U do ij,HE[op(ij)] end;</Text-field>

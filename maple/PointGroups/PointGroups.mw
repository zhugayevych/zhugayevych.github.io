<Section collapsed="true" isCollapsible="true" drawButton="true" MultipleChoiceAnswerIndex="-1" MultipleChoiceRandomizeChoices="false" TrueFalseAnswerIndex="-1" EssayAnswerRows="5" EssayAnswerColumns="60"><Title><Text-field style="Heading 1" layout="Heading 1">Applications: Tensors</Text-field></Title>
<Group labelreference="L58908" drawlabel="true">
<Input><Text-field style="Normal" layout="Normal">Indexing</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">id:=proc(i::posint,j::posint)
local a;
a:=sort([i,j]);
if   a=[1,1] then 1
elif a=[2,2] then 2
elif a=[3,3] then 3
elif a=[2,3] then 4
elif a=[1,3] then 5
elif a=[1,2] then 6
else error &quot;Incorrect indexes&quot;,k end
end:

iid:=proc(n::posint)
if n&lt;=3 then n,n
elif n=4 then 2,3
elif n=5 then 1,3
elif n=6 then 1,2
else error &quot;Incorrect index&quot;,n end
end:

A2exV:=A-&gt;Vector(6,n-&gt;A[iid(n)]):
exV2A:=V-&gt;Matrix(3,(i,j)-&gt;V[id(i,j)],shape=symmetric):
A2exM:=A-&gt;Matrix(6,(n,m)-&gt;A[iid(n),iid(m)],shape=symmetric):
exM2A:=M-&gt;Array(1..3,1..3,1..3,1..3,(i,j,k,l)-&gt;B[id(i,j),id(k,l)]):

T2exT:=T-&gt;Matrix(6,proc(n,m) local i,j,i2,j2;
 i,j:=iid(n);
 i2,j2:=iid(m);
 if i2=j2 then T[i,i2]*T[j,j2]
 else T[i,i2]*T[j,j2]+T[i,j2]*T[j,i2] end end):
</Text-field>
</Input>
</Group>

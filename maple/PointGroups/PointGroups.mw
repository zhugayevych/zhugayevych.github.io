<Section collapsed="true" isCollapsible="true" drawButton="true" MultipleChoiceAnswerIndex="-1" MultipleChoiceRandomizeChoices="false" TrueFalseAnswerIndex="-1" EssayAnswerRows="5" EssayAnswerColumns="60"><Title><Text-field style="Heading 1" layout="Heading 1">Point groups relations</Text-field></Title>
<Group labelreference="L58973" drawlabel="true">
<Input><Text-field style="Text" layout="Normal">Generate groups</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">ct:=time():
for n in [$1..6,8,10,12] do
 C||n:=tbPG[&quot;C&quot;](n):-GF(tbPG[&quot;C&quot;](n):-gen);
 D||n:=tbPG[&quot;D&quot;](n):-GF(tbPG[&quot;D&quot;](n):-gen);
 C||n||i:=tbPG[&quot;Ci&quot;](n):-GF(tbPG[&quot;Ci&quot;](n):-gen);
 C||n||v:=tbPG[&quot;Cv&quot;](n):-GF(tbPG[&quot;Cv&quot;](n):-gen);
 D||n||i:=tbPG[&quot;Di&quot;](n):-GF(tbPG[&quot;Di&quot;](n):-gen) end:
for n from 2 by 2 to 12 do
 C||n||h:=tbPG[&quot;Ch&quot;](n):-GF(tbPG[&quot;Ch&quot;](n):-gen);
 D||n||h:=tbPG[&quot;Dh&quot;](n):-GF(tbPG[&quot;Dh&quot;](n):-gen) end:
for n from 1 by 2 to 5 do
 C||n||h:=C||(2*n)||i;
 D||n||h:=D||(2*n)||i end:
for n from 1 to 6 do
 C||n||d:=C||(`if`(type(n,odd),n,2*n))||i;
 D||n||d:=D||(`if`(type(n,odd),n,2*n))||i;
 S||n:=C||(`if`(type(n,odd),2*n,`if`(type(n/2,odd),n/2,n)))||i end:
T:=tbPG[&quot;T&quot;]:-GF(tbPG[&quot;T&quot;]:-gen):
Th:=tbPG[&quot;Th&quot;]:-GF(tbPG[&quot;Th&quot;]:-gen):
Td:=tbPG[&quot;Td&quot;]:-GF(tbPG[&quot;Td&quot;]:-gen):
K:=tbPG[&quot;O&quot;]:-GF(tbPG[&quot;O&quot;]:-gen):
Kh:=tbPG[&quot;Oh&quot;]:-GF(tbPG[&quot;Oh&quot;]:-gen):
Y:=tbPG[&quot;Y&quot;]:-GF(tbPG[&quot;Y&quot;]:-gen):
Yh:=tbPG[&quot;Yh&quot;]:-GF(tbPG[&quot;Yh&quot;]:-gen):
time()-ct;</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="LUkjbW5HNiMvSSttb2R1bGVuYW1lRzYiSSxUeXBlc2V0dGluZ0dJKF9zeXNsaWJHRic2JFEpMC44OTEwMDBGJy8lLG1hdGh2YXJpYW50R1Enbm9ybWFsRic=">JCIkIiopISIk</Equation></Text-field>
</Output>
</Group>

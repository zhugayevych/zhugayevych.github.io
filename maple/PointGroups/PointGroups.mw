<Section collapsed="true" isCollapsible="true" drawButton="true" MultipleChoiceAnswerIndex="-1" MultipleChoiceRandomizeChoices="false" TrueFalseAnswerIndex="-1" EssayAnswerRows="5" EssayAnswerColumns="60"><Title><Text-field style="Heading 1" layout="Heading 1">Basis-specific IR transformations</Text-field></Title>
<Group labelreference="L59591" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">Initialize</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">xyznorm:=proc(e,vars,$) local V,l,u,v;  V:=coeffs2(map(simplify,expand(e)),vars);
 l:=add(u,u=V[1][..3]);  for v in V[2..] do if (add(u,u=v[..3])&lt;&gt;l) then error(&quot;Term %1 is inconsistent with l=%2&quot;,v,l) end end;
 add(`if`(foldl(`and`,op(map(type,v[..3],even))),mul(GAMMA((u+1)/2),u=v[..3])*v[4],0),v=V)*2/GAMMA((l+3)/2) end:
</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L59569" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">Load group</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">GR:=tbPG[<Font opaque="true" background="[255,255,153]">&quot;Oh&quot;]</Font>:
gens:=GR:-namegen;  gen:=GR:-gen:  G:=GR:-GF(gen):  ng:=nops(G):  geni:=map(FG_member,gen,G):  IRs:=GR:-nameR:  nr:=nops(IRs):  i2i:=FG_invTable(G):  #ij2i:=FG_mulTable(G):
R2gen:=table(zip(`=`,GR:-nameR,zip(genR_real,GR:-genR,GR:-nameR))):
IRT:=table([seq(IR=GR:-GF(R2gen[IR]),IR=IRs)]):
interface(rtablesize=max(12,nops(IRs)+1)): FGR_ChTb(GR,fulloutput);</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SSVnZW5zR0YoNyRRJGNpNEYoUSR1MktGKDcjRi4=</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
<Group hide-input="false" labelreference="L59567" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">Load basis</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">unassign('x,y,z');
basis:=copy<Font opaque="true" background="[255,255,153]">(basR_Oh_D2h)</Font>:
if (sort([indices(basis,nolist)])&lt;&gt;sort(IRs)) then error(&quot;Inconsistent IRs&quot;) end;
for IR in IRs do basis[IR]:=map(v-&gt;subsop(2=parse(v[2]),v),basis[IR]) end:  op(op(basis));</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
<Group hide-input="false" labelreference="L59566" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">Calculate genR</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">genonly:=<Font opaque="true" background="[255,255,153]">false</Font>;
genR2:=[]:
for IR in IRs do
 V:=map2(op,2,basis[IR]);  dim:=nops(V);  nrm:=map(v-&gt;sqrt(xyznorm(v^2,[x,y,z])),V);  if (nrm&lt;&gt;[nrm[1]$dim]) then WARNING(&quot;Inhomogeneous normalization for IR=%1, nrm=%2&quot;,IR,nrm) end;
 for k from 2 to dim do for k2 from 1 to k-1 do if (xyznorm(V[k]*V[k2],[x,y,z])&lt;&gt;0) then error(&quot;Nonorthogonal basis for IR=%1, k=%2, k2=%3&quot;,IR,k,k2) end end end;
 ls:=[];  for i in `if`(genonly,geni,[$1..ng]) do  r:=G[i2i[i]].&lt;x,y,z&gt;;
   V2:=simplify(subs({x=r[1],y=r[2],z=r[3]},V));  ls:=[op(ls),Matrix(dim,(k,k2)-&gt;xyznorm(V[k]*V2[k2],[x,y,z])/nrm[k]/nrm[k2])] end;
 genR2:=[op(genR2),ls] end:  seq(IRs[r]=genR2[r][`if`(genonly,..,geni)],r=1..nr);</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyM+SShnZW5vbmx5R0YoSSZmYWxzZUdGJjcjRi4=</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
<Group hide-input="false" labelreference="L59581" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">Compare with the standard genR</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">genR1:=seq(R2gen[IR],IR=IRs):
for r from 1 to nr do for i from 1 to nops(geni) do if not(FG_ident(genR1[r][i],genR2[r][`if`(genonly,i,geni[i])])) then
 print(r,IRs[r],i,genR1[r][i]&lt;&gt;genR2[r][`if`(genonly,i,geni[i])]) end end end;  printf(&quot;Done&quot;);</Text-field>
</Input>
<Output><Text-field style="Line Printed Output" layout="Line Printed Output">Done</Text-field>

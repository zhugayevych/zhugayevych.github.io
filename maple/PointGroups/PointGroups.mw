<Input><Text-field style="Text" layout="Normal">Initialize site basis set (SBS) and United SBS: select cubic harmonics and initialize site representation generators</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">Lmax:=<Font opaque="true" background="[255,255,153]">1</Font>; 
SBS:=[seq(op(YxyzL(L)),L=0..Lmax)];
SBSxyz:=[seq(op(Yxyz(L,&quot;cubic&quot;,x,y,z)),L=0..Lmax)];
tbM:=table([seq(L=YxyzM(L,&quot;cubic&quot;),L=0..Lmax)]):
genT0:=[seq(DiagonalMatrix([seq(FG_simplify(tbM[L].RepDL(g,L).tbM[L]^(-1)),L=0..Lmax)]),g=gen)]:
FG_equal([seq(v[2..4,2..4],v=genT0)],gen); # extracheck
lslsk:=LinearAlgebra[StronglyConnectedBlocks](add(13^n*genT0[n],n=1..nops(genT0)),'outputform'='rowlist');
USBS2k:=table([seq(Join(SBS[lsk],&quot;;&quot;)=lsk,lsk=lslsk)]);
USBS:=Sort([indices(USBS2k,nolist)],v-&gt;USBS2k[v][1]);
USBS2g:=table([seq(v=map(u-&gt;u[USBS2k[v]$2],genT0),v=USBS)]);
SBS2ul:=table([seq(seq(SBS[USBS2k[v][k]]=[v,k],k=1..nops(USBS2k[v])),v=USBS)]):
#Add 1 custom orbital
SBS:=[op(SBS),&quot;A&quot;];
USBS2k[&quot;A&quot;]:=[nops(SBS)];
USBS:=[op(USBS),&quot;A&quot;];
SBS2ul[&quot;A&quot;]:=[&quot;A&quot;,1];
#Customize orbital
USBS2g[&quot;A&quot;]:=[&lt;&lt;1&gt;&gt;,&lt;&lt;-1&gt;&gt;,&lt;&lt;1&gt;&gt;]; # benzene CC antibonding orbital</Text-field>
</Input>

<Input><Text-field style="Text" layout="Normal">Determine generic Hamiltonian</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">EE:=table():
HE:=Matrix(N,shape=symmetric):
abc:=cat(seq(StringTools[Char](i),i=97..122)):
rij2v:=(IR,i,j)-&gt;EE[cat(IR,abc[min(i,j)],abc[max(i,j)])]:
varids:=[seq(seq(seq([IR,i,j],j=i..nops(tbIR[IR])),i=1..nops(tbIR[IR])),IR=IRs)];
nv:=nops(varids);
k2v:=k-&gt;rij2v(op(varids[k])):
v2k:=table([seq(k2v(k)=k,k=1..nv)]):
for IR in IRs do  v:=tbIR[IR];  n:=nops(v);  for i from 1 to n do for j from 1 to n do
  HE[v[i][4],v[j][4]]:=HE[v[i][4],v[j][4]]+simplify(v[i][3].Transpose(v[j][3]))*`if`(i=j,1,1/2)*rij2v(IR,i,j) end end end:
vars:=[seq(EE[cat(id[1],abc[id[2]],abc[id[3]])],id=varids)]:
verify(indets(HE),{op(vars)},set); #extracheck</Text-field>
</Input>

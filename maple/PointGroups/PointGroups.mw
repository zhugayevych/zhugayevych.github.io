if (ng&gt;48) then error(&quot;Cannot generate lookup tables&quot;) else  i2i:=FG_invTable(G):  ij2i:=FG_mulTable(G):  c2c2:=map(i-&gt;i2C(ij2i[i,i]),FGR_indexC(GR)) end:

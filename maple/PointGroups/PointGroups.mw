<Input><Text-field style="Text" layout="Normal">Determine irreducible representations</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">tbIR:=table():
maxlen:=4+max(map(length,USBS)):
for o from 1 to no do
 R:=FG_RegRep(G,map2(op,2,A[orbs[o]]),x-&gt;evalf(abs(x)<Font opaque="true" background="[255,255,153]">&lt;1e-8)</Font>);  genR1:=R[geni];
 BS1:=OBS[o];
 if (BS1=[]) then next end;
 for b in BS1 do
  b,l:=op(SBS2ul[b]);  print(b,l);
  if (l&gt;1) then next end;
  genT:=zip(KroneckerProduct,genR1,USBS2g[b]);  RT:=GR:-GF(genT);  IR1:=FGR_RepDec(RT,GR,aslist);
<Font encoding="UTF-8">  printf(&quot;%2d %-*s %{c,}s\134n&quot;,o,maxlen,osb2B(o,1,b),</Font>Vector(map(v-&gt;sprintf(&quot;%d%s&quot;,nops(v[2]),v[1]),IR1)));
  for v in IR1 do tbIR[v[1],o,b]:=v[2] end end end:
V:=remove(v-&gt;v[1]=0,[seq([add(add(`if`(assigned('tbIR[IR,o,b]'),nops(tbIR[IR,o,b]),0),b=USBS),o=1..no),IR],IR=IRs)]):
<Font encoding="UTF-8">printf(&quot;Total %d: %{c,}s\134n&quot;,</Font>add(v[1]*PGrepdim(v[2]),v=V),Vector(map(v-&gt;sprintf(&quot;%d%s&quot;,op(v)),V)));
for IR in IRs do tbIR[IR]:=[seq(seq(`if`(assigned('tbIR[IR,o,b]'),seq([o,b,`if`(IR[1]=&quot;E&quot;,CorrectErep(v),v),ou2lsk(o,b)],v=tbIR[IR,o,b]),NULL),b=USBS),o=1..no)] end:
IRs2:=remove(v-&gt;tbIR[v]=[],IRs);</Text-field>

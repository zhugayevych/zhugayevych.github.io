<Section collapsed="true" isCollapsible="true" drawButton="true" MultipleChoiceAnswerIndex="-1" MultipleChoiceRandomizeChoices="false" TrueFalseAnswerIndex="-1" EssayAnswerRows="5" EssayAnswerColumns="60"><Title><Text-field style="Heading 1" layout="Heading 1">Representations of IR products</Text-field></Title>
<Group hide-input="false" labelreference="L59762" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">1) group element index to class index function; 2) Kronecker product; 3,4) Symmetrized and antisymmetrized Kronecker square</Text-field><Text-field prompt="&gt; " style="Maple Input" layout="Normal">i2C:=proc(i::posint,$) local Ci,j,c;  Ci:=FGR_indexC(GR);  for j from 1 to ng do  c:=SearchPos(Ci,ij2i[ij2i[j,i],i2i[j]]);  if (c&gt;0) then return c end end;  0 end:
KroneckerProduct2:=proc(M1,M2) local n1,m1,n2,m2,i1,j1,i2,j2,MM;  n1,m1:=Dim2(M1);  n2,m2:=Dim2(M2);  MM:=Matrix(n1*n2,m1*m2);  for i1 from 1 to n1 do for i2 from 1 to n2 do for j1 from 1 to m1 do for j2 from 1 to m2 do MM[idL([i2-1,i1-1],[n2,n1]),idL([j2-1,j1-1],[m2,m1])]:=M2[i2,j2]*M1[i1,j1] end end end end;  MM end:
SymKronSq:=proc(M) local n,i1,j1,i2,j2,MM;  n:=Dim2(M)[1];  MM:=Matrix(n*(n+1)/2);  for i1 from 1 to n do for i2 from 1 to i1 do for j1 from 1 to n do for j2 from 1 to j1 do MM[idS([i1,i2]),idS([j1,j2])]:=(M[i1,j1]*M[i2,j2]+M[i1,j2]*M[i2,j1])/`if`(i1=i2,sqrt(2),1)/`if`(j1=j2,sqrt(2),1) end end end end;  MM end:
AsymKronSq:=proc(M) local n,i1,j1,i2,j2,MM;  n:=Dim2(M)[1];  MM:=Matrix(n*(n-1)/2);  for i1 from 1 to n do for i2 from 1 to i1-1 do for j1 from 1 to n do for j2 from 1 to j1-1 do MM[idA([i1,i2]),idA([j1,j2])]:=M[i1,j1]*M[i2,j2]-M[i1,j2]*M[i2,j1] end end end end;  MM end:

xyznorm:=proc(e,vars,$) local V,l,u,v;  V:=coeffs2(map(simplify,expand(e)),vars);
 l:=add(u,u=V[1][..3]);  for v in V[2..] do if (add(u,u=v[..3])&lt;&gt;l) then error(&quot;Term %1 is inconsistent with l=%2&quot;,v,l) end end;
 add(`if`(foldl(`and`,op(map(type,v[..3],even))),mul(GAMMA((u+1)/2),u=v[..3])*v[4],0),v=V)*2/GAMMA((l+3)/2) end:
normalizexyz:=e-&gt;e/sqrt(xyznorm(e^2,[x,y,z])):
</Text-field>
</Input>
</Group>

<Group labelreference="L58967" drawlabel="true">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">PGs:=remove(s-&gt;member(s,[&quot;C2i&quot;,&quot;C6i&quot;,&quot;D1&quot;,&quot;D1d&quot;,&quot;D8d&quot;,&quot;D1h&quot;,&quot;C1v&quot;]),[seq(seq(cat(s[1],n,s[2]),n=[1,2,3,4,5,6,8]),s=[&quot;C&quot;,&quot;Ci&quot;,&quot;Ch&quot;,&quot;D&quot;,&quot;Dd&quot;,&quot;Dh&quot;,&quot;Cv&quot;]),&quot;T&quot;,&quot;Th&quot;,&quot;Td&quot;,&quot;O&quot;,&quot;Oh&quot;,&quot;Y&quot;,&quot;Yh&quot;]);</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
<Group labelreference="L58971" drawlabel="true">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">tb:=table():
sf:=e-&gt;simplify(convert(e,'radical')):
for PG in PGs do
 if (PG[1]=&quot;C&quot; or PG[1]=&quot;D&quot;) then
  s:=StringTools[Remove](StringTools[IsDigit],PG);
  n:=parse(PG[2]);
  if   (s=&quot;Ch&quot; and type(n,odd)) then r,m:=&quot;Ci&quot;,2*n
  elif (s=&quot;Dh&quot; and type(n,odd)) then r,m:=&quot;Di&quot;,2*n
  elif (s=&quot;Dd&quot;) then r,m:=&quot;Di&quot;,`if`(type(n,odd),n,2*n)
  else r,m:=s,n end;
  v:=tbPG[r](m);
  G:=v:-GF(v:-gen);
  if (s=&quot;Dd&quot; or s=&quot;Cv&quot; and type(n,odd)) then
   T,Ti:=map(sf,RotationM(Pi/2/n,&lt;0,0,1&gt;)),map(sf,RotationM(-Pi/2/n,&lt;0,0,1&gt;));
   G:=map(g-&gt;map(simplifyradical,Ti.g.T),G) end;
  if (n=5) then
   G:=map(g-&gt;map(simplifyradical,g),G) end
 else
  v:=tbPG[PG];
  G:=v:-GF(v:-gen) end;
 tb[PG]:=G end:
</Text-field>
</Input>
</Group>

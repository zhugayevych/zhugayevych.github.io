for IR in IRs do tbIR[IR]:=[seq(seq(`if`(assigned('tbIR[IR,o,b]'),seq([o,b,`if`(IR[1]=&quot;E&quot;,NormalizeMatrix(simplify(v.HermitianTranspose(genR_TME)),'positive',2),v),ou2lsk(o,b)],v=tbIR[IR,o,b]),NULL),b=USBS),o=1..no)] end:
IRs2:=remove(v-&gt;tbIR[v]=[],IRs);</Text-field>

<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">F1:=table([seq(v=[],v=IR)]):  F2,F3:=copy(F1),copy(F1):
ct:=time(): <Font encoding="UTF-8">for L from 0 to Lmax do  printf(&quot;L=%d\134n&quot;,L);
</Font> perm:=ListTools[Interleave]([(L-m+1)$m=0..L],[$L+2..2*L+1]):
 T:=DiagonalMatrix([1,seq(`if`(type(m,odd),&lt;&lt;-1,I&gt;|&lt;1,I&gt;&gt;,&lt;&lt;1,-I&gt;|&lt;1,I&gt;&gt;)/sqrt(2),m=1..L)]);
 gen:=map2(map,FG_simplify,map(RepDL,GR:-namegen,L)):
 R:=map2(map,FG_simplify,GR:-GF(gen)):
 ls:=map(v-&gt;subsop(2=map(simplifyradical,v[2]),v),FGR_RepDec(R,GR));
 for v in ls do
  r,v1:=v[1],v[2][perm,..];  F1[r]:=[op(F1[r]),simplify(T.v1)];
  if (L&lt;=4) then
   v2:=Matrix(ColumnSpace(simplify(TM[L].v1)));
   v3:=Vector[row](YxyzL(L)).v2;
   for l from 2 to 3 do (F||l)[r]:=[op((F||l)[r]),v||l] end end end end: time()-ct;</Text-field>

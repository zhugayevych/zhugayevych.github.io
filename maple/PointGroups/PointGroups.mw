if (sort([indices(basis,nolist)])&lt;&gt;sort(IRs)) then basis:=[]; WARNING(&quot;No basis&quot;) else for IR in IRs do basis[IR]:=map(v-&gt;subsop(2=parse(v[2]),v),basis[IR]) end end:

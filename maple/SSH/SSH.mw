ft:=proc(j) local e;  e:=sscanf(j[4],&quot;%{3;d(:)}dc&quot;);  if type(e[1],Vector) then &lt;3600,60,1&gt;.e[1] else 0 end end:
cpuuse:=SortM([seq([ u[1][3],
 add(`if`(j[5]=&quot;R&quot;,fnp(j),0),j=u),
 add(`if`(j[5]=&quot;R&quot; and ft(j)/fnp(j)&gt;7*24*3600,fnp(j),0),j=u),
 add(`if`(j[5]=&quot;R&quot; and ft(j)/fnp(j)&gt;30*24*3600,fnp(j),0),j=u),
 add(`if`(j[5]=&quot;Q&quot;,sscanf(j[7],&quot;/%d&quot;)[1],0),j=u),
 add(`if`(j[5]=&quot;R&quot;,ft(j),0),j=u)/7/24/3600 ],u=ls)],[-1,2,3,4]):
l:=max(seq(length(u[1]),u=cpuuse)):
<Font encoding="UTF-8">printf(&quot; %-*s   R  R/w R/m   Q  cpu-weeks\134n%s\134n&quot;,l,&quot;user&quot;,cat(&quot;-&quot;$(l+30)));
</Font>for u in cpuuse do printf(&quot;%-*s%5d%4d%4d%5d<Font encoding="UTF-8">%7.0f\134n&quot;,l,op(u)) end;
printf(&quot;%s\134n %-*s%4d%4d%4d%5d%7.0f\134n&quot;,</Font>cat(&quot;-&quot;$(l+30)),l,&quot;total&quot;,seq(add(u[i],u=cpuuse),i=2..6));</Text-field>
</Input>

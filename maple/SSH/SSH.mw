l:=max(seq(length(u[1]),u=cpuuse)):
<Font encoding="UTF-8">printf(&quot; %-*s   R  R/w R/m   Q  cpu-weeks\134n%s\134n&quot;,l,&quot;user&quot;,cat(&quot;-&quot;$(l+30)));
